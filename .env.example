VITE_APP_TITLE=OctWa
VITE_APP_VERSION=1.0.3
VITE_APP_ENVIRONMENT=production

# ─── Octra Network RPC ───────────────────────────────────────────────────────
# Default RPC endpoints for the wallet's built-in Mainnet / Devnet providers.
# Users can override these at runtime in Wallet Settings → RPC Providers.
# Edit these to point the whole wallet (UI + extension service worker) at a
# different node; both the React build and the background service worker
# read from these values at build time.
VITE_OCTRA_RPC_URL_MAINNET=http://46.101.86.250:8080
VITE_OCTRA_RPC_URL_DEVNET=http://165.227.225.79:8080

# Infura Project ID — used as default RPC for all EVM networks (Ethereum, Polygon, Base, BSC)
# Get a free key at https://app.infura.io/
VITE_INFURA_API_KEY=your_infura_project_id_here

# Etherscan API Key — used for transaction history
# Works without a key but rate-limited. Get a free key at https://etherscan.io/myapikey
VITE_ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ONS (Octra Name Service) contract addresses per network.
# Resolvable names are disabled for any network whose contract is left blank.
VITE_ONS_CONTRACT_DEVNET=
VITE_ONS_CONTRACT_MAINNET=
