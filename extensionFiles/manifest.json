{
  "manifest_version": 3,
  "name": "OctWa - Octra Wallet",
  "version": "1.3.1",
  "description": "Private-first wallet for seamless interaction with the Octra encrypted network.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "OctWa - Octra Wallet",
    "default_icon": {
      "16": "icons/octwa16x16.png",
      "32": "icons/octwa32x32.png",
      "48": "icons/octwa48x48.png",
      "128": "icons/octwa128x128.png"
    }
  },
  "omnibox": { "keyword": "octwa" },
  "icons": {
    "16": "icons/octwa16x16.png",
    "32": "icons/octwa32x32.png",
    "48": "icons/octwa48x48.png",
    "128": "icons/octwa128x128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "web_accessible_resources": [
    {
      "resources": ["index.html", "provider.js", "core.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
